{{!-- Flag Widget Partial – blacksmith-flag-widget --}}
{{!-- Pass context from FlagWidget.prepareData(). --}}
<div class="bsw-flag-widget" data-flag-widget="{{contextKey}}">

    {{#if isFullMode}}
        {{!-- Hidden field stores the canonical comma-separated flag value --}}
        <input type="hidden" data-flag-value value="{{#each chips}}{{#unless @first}},{{/unless}}{{key}}{{/each}}">

        {{!-- Current flags as removable chips --}}
        <div class="bsw-flag-chips" data-flag-chips>
            {{#each chips}}
                <span class="bsw-flag-chip{{#if protected}} bsw-flag-chip--protected{{/if}}" data-flag-key="{{key}}">
                    {{label}}
                    {{#if removable}}
                        <button type="button" class="bsw-flag-chip-remove" data-remove-flag="{{key}}" aria-label="Remove {{label}}">×</button>
                    {{/if}}
                </span>
            {{/each}}
        </div>

        {{!-- Text input + suggestion dropdown --}}
        <div class="bsw-flag-input-row">
            <input type="text"
                   class="bsw-flag-input"
                   data-flag-input
                   placeholder="{{placeholder}}"
                   autocomplete="off">
        </div>
        <div class="bsw-flag-suggestions" data-flag-suggestions hidden>
            {{#each suggestions}}
                <button type="button" class="bsw-flag-suggestion" data-suggest-flag="{{key}}">{{label}}</button>
            {{/each}}
        </div>
    {{/if}}

    {{#if isFilterMode}}
        {{!-- Filter mode: visibility toggles for each flag --}}
        <div class="bsw-flag-filter-list">
            {{#each filterItems}}
                <label class="bsw-flag-filter-item">
                    <input type="checkbox"
                           class="bsw-flag-filter-toggle"
                           data-filter-flag="{{key}}"
                           data-filter-context="{{../contextKey}}"
                           {{#if visible}}checked{{/if}}>
                    <span class="bsw-flag-filter-label{{#if protected}} bsw-flag-filter-label--protected{{/if}}">
                        {{label}}
                    </span>
                </label>
            {{/each}}
            {{#unless filterItems}}
                <span class="bsw-flag-filter-empty">No flags defined for this context.</span>
            {{/unless}}
        </div>
    {{/if}}

</div>
