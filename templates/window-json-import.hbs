<div class="blacksmith-window-template-root blacksmith-json-import-window" id="{{appId}}">
    {{#if showHeader}}
    <header class="blacksmith-window-template-header">
        <div class="blacksmith-window-template-header-content">
            <div class="blacksmith-window-template-header-icon">
                {{#if headerIcon}}<i class="{{headerIcon}}"></i>{{else}}<i class="fa-solid fa-hammer"></i>{{/if}}
            </div>
            <div class="blacksmith-window-template-header-title-block">
                <div class="blacksmith-window-template-header-title">{{windowTitle}}</div>
                <div class="blacksmith-window-template-header-subtitle">{{subtitle}}</div>
            </div>
            <div class="blacksmith-window-template-header-right">
                {{#if headerRight}}{{{headerRight}}}{{/if}}
            </div>
        </div>
    </header>
    {{/if}}

    <div class="blacksmith-window-template-body">
        <section class="blacksmith-window-section blacksmith-json-import-section blacksmith-json-import-section-copy">
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-clipboard"></i>
                    <span>Select Prompt Template</span>
                </div>
                <div class="blacksmith-field-row blacksmith-json-import-template-row">
                    <div class="blacksmith-field">
                        <select class="blacksmith-select blacksmith-json-import-template-select" {{#unless hasTemplates}}disabled{{/unless}}>
                            {{#if hasTemplates}}
                                {{#each templateOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                {{/each}}
                            {{else}}
                                <option value="">No templates</option>
                            {{/if}}
                        </select>
                    </div>
                    <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-copy-template" {{#unless hasTemplates}}disabled{{/unless}}>
                        <i class="fa-solid fa-clipboard"></i> {{copyTemplateLabel}}
                    </button>
                </div>
                {{#if journalAreaUi.hasJournalAreaUi}}
                <div class="blacksmith-json-import-journal-area" data-for-template="{{journalAreaUi.showForTemplate}}">
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>Location path (Area template)</span>
                    </div>
                    <div class="blacksmith-json-import-journal-location-row">
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-folder">
                            <span class="blacksmith-json-import-prompt-field-label">{{journalAreaUi.folder.label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalAreaUi.folder.id}}" value="{{journalAreaUi.folder.value}}" autocomplete="off">
                        </label>
                        <span class="blacksmith-json-import-location-sep blacksmith-json-import-location-sep-pipe" aria-hidden="true">|</span>
                        {{#each journalAreaUi.geography}}
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-geo-field">
                            <span class="blacksmith-json-import-prompt-field-label">{{label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}" value="{{value}}" autocomplete="off">
                        </label>
                        {{#unless @last}}<span class="blacksmith-json-import-location-sep blacksmith-json-import-location-sep-chevron" aria-hidden="true">&gt;</span>{{/unless}}
                        {{/each}}
                        <label class="blacksmith-json-import-prompt-checkbox blacksmith-json-import-geography-default">
                            <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input" data-prompt-checkbox="{{journalAreaUi.geographyDefault.id}}">
                            <span>{{journalAreaUi.geographyDefault.label}}</span>
                        </label>
                    </div>
                    <div class="blacksmith-json-import-journal-image-rows">
                        {{#each journalAreaUi.images}}
                        <div class="blacksmith-json-import-journal-image-row">
                            <div class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-image-field">
                                <span class="blacksmith-json-import-prompt-field-label">{{fieldLabel}}</span>
                                <div class="blacksmith-json-import-image-path-row">
                                    <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{fieldId}}" value="{{value}}" autocomplete="off" placeholder="modules/...">
                                    <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-image-browse" data-prompt-field-target="{{fieldId}}" title="Browse for image">
                                        <i class="fa-solid fa-folder-open"></i> Browse
                                    </button>
                                </div>
                            </div>
                            <label class="blacksmith-json-import-prompt-checkbox">
                                <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input" data-prompt-checkbox="{{checkboxId}}" {{#if checked}}checked{{/if}}>
                                <span>{{checkboxLabel}}</span>
                            </label>
                            <label class="blacksmith-json-import-prompt-checkbox blacksmith-json-import-image-default">
                                <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input" data-prompt-checkbox="{{defaultCheckboxId}}">
                                <span>{{defaultLabel}}</span>
                            </label>
                        </div>
                        {{/each}}
                    </div>
                </div>
                {{/if}}
                {{#if hasPromptFields}}
                <div class="blacksmith-json-import-prompt-fields">
                    <div class="blacksmith-json-import-prompt-fields-grid">
                        {{#each promptFields}}
                        <label class="blacksmith-json-import-prompt-field-row" data-for-template="{{showForTemplate}}">
                            <span class="blacksmith-json-import-prompt-field-label">{{label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}" value="{{value}}" autocomplete="off">
                        </label>
                        {{/each}}
                    </div>
                </div>
                {{/if}}
                {{#if hasPromptCheckboxes}}
                <div class="blacksmith-json-import-prompt-options">
                    <span class="blacksmith-json-import-prompt-options-hint">Append to copied prompt:</span>
                    {{#each promptCheckboxes}}
                    <label class="blacksmith-json-import-prompt-checkbox">
                        <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input" data-prompt-checkbox="{{id}}" {{#if checked}}checked{{/if}} {{#if disabled}}disabled{{/if}}>
                        <span>{{label}}</span>
                    </label>
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </section>

        <section class="blacksmith-window-section blacksmith-json-import-section blacksmith-json-import-section-import">
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-file-import"></i>
                    <span>Import JSON</span>
                </div>
                <div class="blacksmith-json-import-content-grid">
                    <div class="blacksmith-json-import-editor">
                        <textarea class="blacksmith-textarea blacksmith-json-import-textarea" placeholder="{{textareaPlaceholder}}">{{initialJson}}</textarea>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <section class="blacksmith-window-template-buttons">
        <div class="blacksmith-window-template-action-bar">
            <div class="blacksmith-window-template-action-left">
                <input class="blacksmith-json-import-file-input" type="file" accept="{{fileInputAccept}}" hidden>
                <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-select-file">
                    <i class="fa-solid fa-folder-open"></i> {{selectFileLabel}}
                </button>
            </div>
            <div class="blacksmith-window-template-action-right">
                <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-submit">
                    <i class="fa-solid fa-file-import"></i> {{importLabel}}
                </button>
            </div>
        </div>
    </section>
</div>
