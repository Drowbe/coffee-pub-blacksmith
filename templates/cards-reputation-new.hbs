<span style="visibility: hidden">coffeepub-hide-header</span>
<div class="blacksmith-card {{themeClassName}}">
    <div class="card-header">
        <i class="fa-solid fa-arrow-trend-up"></i> Reputation Change
    </div>
    <div class="section-content">
        <div class="section-header"><i class="fas fa-map"></i> {{sceneName}}</div>
        <p><strong></strong></p>
        <div class="section-header"><i class="fas fa-arrows-left-right"></i> Change</div>
        <p><strong>{{change}}</strong> ({{previousValue}} → {{newValue}})</p>
        <div class="section-header"><i class="fas fa-gauge-high"></i> Standing</div>
        <p><strong>{{newValue}}</strong> — {{scaleLabel}}</p>
        {{#if scaleDescription}}
        <p class="section-description">{{scaleDescription}}</p>
        {{/if}}
    </div>
</div>
