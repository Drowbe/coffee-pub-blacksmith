<div class="blacksmith-json-import-body">
    <div class="blacksmith-json-import-tab-panel" data-json-import-panel="authoring" {{#unless isAuthoringTab}}hidden{{/unless}}>
        <section class="blacksmith-window-section blacksmith-json-import-section blacksmith-json-import-section-copy">
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-list"></i>
                    <span>{{authoringHeading}}</span>
                </div>
                <div class="blacksmith-field-row blacksmith-json-import-template-row">
                    <div class="blacksmith-field blacksmith-json-import-template-field">
                        <select class="blacksmith-select blacksmith-json-import-template-select" {{#unless hasTemplates}}disabled{{/unless}}>
                            {{#if hasTemplates}}
                                {{#each templateOptions}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                {{/each}}
                            {{else}}
                                <option value="">No templates</option>
                            {{/if}}
                        </select>
                    </div>
                    {{#if hasAuthoringGuide}}
                    <div class="blacksmith-field blacksmith-json-import-format-field">
                        <label class="blacksmith-json-import-prompt-field-label">Output</label>
                        <select class="blacksmith-select blacksmith-json-import-json-output-select">
                            {{#each jsonOutputOptions}}
                            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                    </div>
                    {{/if}}
                </div>
                {{#if journalAreaUi.hasJournalAreaUi}}
                <div class="blacksmith-json-import-journal-area" data-for-template="{{journalAreaUi.showForTemplate}}">
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>Location path (Area template)</span>
                    </div>
                    <div class="blacksmith-json-import-journal-fields-grid">
                    <div class="blacksmith-json-import-journal-location-row blacksmith-json-import-journal-fields-row-full">
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-folder">
                            <span class="blacksmith-json-import-prompt-field-label">{{journalAreaUi.folder.label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalAreaUi.folder.id}}" value="{{journalAreaUi.folder.value}}" autocomplete="off">
                        </label>
                        <span class="blacksmith-json-import-location-sep blacksmith-json-import-location-sep-pipe" aria-hidden="true">|</span>
                        {{#each journalAreaUi.geography}}
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-geo-field">
                            <span class="blacksmith-json-import-prompt-field-label">{{label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}" value="{{value}}" autocomplete="off">
                        </label>
                        {{#unless @last}}<span class="blacksmith-json-import-location-sep blacksmith-json-import-location-sep-chevron" aria-hidden="true">&gt;</span>{{/unless}}
                        {{/each}}
                    </div>
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header blacksmith-json-import-journal-fields-row-full">
                        <i class="fa-solid fa-sliders"></i>
                        <span>Generation direction</span>
                    </div>
                    <div class="blacksmith-json-import-area-generation-grid blacksmith-json-import-journal-fields-row-full">
                        {{#each journalAreaUi.generationOptions}}
                        <label class="blacksmith-json-import-prompt-field-row">
                            <span class="blacksmith-json-import-prompt-field-label">{{label}}</span>
                            <select class="blacksmith-select blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}">
                                {{#each options}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                {{/each}}
                            </select>
                        </label>
                        {{/each}}
                    </div>
                    <div class="blacksmith-json-import-journal-image-rows blacksmith-json-import-journal-fields-row-full">
                        {{#each journalAreaUi.images}}
                        <div class="blacksmith-json-import-journal-image-row">
                            <div class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-image-field">
                                <span class="blacksmith-json-import-prompt-field-label">{{fieldLabel}}</span>
                                <div class="blacksmith-json-import-image-path-row">
                                    <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input blacksmith-json-import-image-toggle" data-prompt-checkbox="{{checkboxId}}" {{#if checked}}checked{{/if}} title="Use this image in generated cards; unchecked leaves the card image empty." aria-label="Use this image in generated cards">
                                    <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{fieldId}}" value="{{value}}" autocomplete="off" placeholder="modules/...">
                                    <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-image-browse" data-prompt-field-target="{{fieldId}}" title="Browse for image">
                                        <i class="fa-solid fa-folder-open"></i> Browse
                                    </button>
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{#if isPromptTab}}
                    <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-fields-row-full blacksmith-json-import-additional-context">
                        <span class="blacksmith-json-import-prompt-field-label">{{journalAreaUi.additionalContext.label}}</span>
                        <textarea class="blacksmith-textarea blacksmith-json-import-prompt-field-textarea" data-prompt-field="{{journalAreaUi.additionalContext.id}}" rows="3" autocomplete="off">{{journalAreaUi.additionalContext.value}}</textarea>
                    </label>
                    {{/if}}
                    </div>
                </div>
                {{/if}}
                {{#if journalLocationUi.hasJournalLocationUi}}
                <div class="blacksmith-json-import-journal-location" data-for-template="{{journalLocationUi.showForTemplate}}">
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <span>Location Narrative (prefill before copy)</span>
                    </div>
                    <div class="blacksmith-json-import-journal-fields-grid">
                    <div class="blacksmith-json-import-journal-location-row blacksmith-json-import-journal-location-meta blacksmith-json-import-journal-fields-row-full">
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-folder">
                            <span class="blacksmith-json-import-prompt-field-label">{{journalLocationUi.folder.label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalLocationUi.folder.id}}" value="{{journalLocationUi.folder.value}}" autocomplete="off">
                        </label>
                        <label class="blacksmith-json-import-prompt-field-row">
                            <span class="blacksmith-json-import-prompt-field-label">{{journalLocationUi.journal.label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalLocationUi.journal.id}}" value="{{journalLocationUi.journal.value}}" autocomplete="off">
                        </label>
                        <label class="blacksmith-json-import-prompt-field-row">
                            <span class="blacksmith-json-import-prompt-field-label">{{journalLocationUi.title.label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalLocationUi.title.id}}" value="{{journalLocationUi.title.value}}" autocomplete="off">
                        </label>
                    </div>
                    <div class="blacksmith-json-import-journal-location-row blacksmith-json-import-journal-fields-row-full">
                        {{#each journalLocationUi.geography}}
                        <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-geo-field">
                            <span class="blacksmith-json-import-prompt-field-label">{{label}}</span>
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}" value="{{value}}" autocomplete="off">
                        </label>
                        {{#unless @last}}<span class="blacksmith-json-import-location-sep blacksmith-json-import-location-sep-chevron" aria-hidden="true">&gt;</span>{{/unless}}
                        {{/each}}
                    </div>
                    <div class="blacksmith-json-import-journal-image-rows blacksmith-json-import-journal-fields-row-full">
                        <div class="blacksmith-json-import-journal-image-row">
                            <div class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-image-field">
                                <span class="blacksmith-json-import-prompt-field-label">{{journalLocationUi.locationImage.fieldLabel}}</span>
                                <div class="blacksmith-json-import-image-path-row">
                                    <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{journalLocationUi.locationImage.fieldId}}" value="{{journalLocationUi.locationImage.value}}" autocomplete="off" placeholder="modules/... or None">
                                    <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-image-browse" data-prompt-field-target="{{journalLocationUi.locationImage.fieldId}}" title="Browse for image">
                                        <i class="fa-solid fa-folder-open"></i> Browse
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{#if isPromptTab}}
                    <label class="blacksmith-json-import-prompt-field-row blacksmith-json-import-journal-fields-row-full blacksmith-json-import-additional-context">
                        <span class="blacksmith-json-import-prompt-field-label">{{journalLocationUi.additionalContext.label}}</span>
                        <textarea class="blacksmith-textarea blacksmith-json-import-prompt-field-textarea" data-prompt-field="{{journalLocationUi.additionalContext.id}}" rows="3" autocomplete="off">{{journalLocationUi.additionalContext.value}}</textarea>
                    </label>
                    {{/if}}
                    </div>
                </div>
                {{/if}}
                {{#if hasPromptFields}}
                <div class="blacksmith-json-import-prompt-fields">
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header blacksmith-json-import-illustration-fields-header" data-for-template="illustration">
                        <i class="fa-solid fa-image"></i>
                        <span>Scene facets (prefill before copy)</span>
                    </div>
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-fields-header blacksmith-json-import-portrait-fields-header" data-for-template="portrait">
                        <i class="fa-solid fa-user"></i>
                        <span>Portrait facets (prefill before copy)</span>
                    </div>
                    {{#each promptFieldGroups}}
                    {{#if hasGroup}}
                    <div class="blacksmith-window-section-header blacksmith-json-import-prompt-field-group-header" data-for-template="{{showForTemplate}}" data-for-field="{{showForField}}">
                        <i class="{{groupIcon}}"></i>
                        <span>{{group}}</span>
                    </div>
                    {{/if}}
                    <div class="blacksmith-json-import-prompt-fields-grid{{#if singleItem}} blacksmith-json-import-prompt-fields-grid-single{{/if}}">
                        {{#each items}}
                        <label class="blacksmith-json-import-prompt-field-row{{#if fullWidth}} blacksmith-json-import-prompt-field-row-full{{/if}}" data-for-template="{{showForTemplate}}" data-for-field="{{showForField}}">
                            <span class="blacksmith-json-import-prompt-field-label">
                                <span>{{label}}</span>
                                {{#if hasHint}}<i class="fa-solid fa-circle-question blacksmith-json-import-field-help" data-tooltip="{{hint}}" tabindex="0" aria-label="{{hint}}"></i>{{/if}}
                            </span>
                            {{#if isSelect}}
                            <select class="blacksmith-select blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}">
                                {{#each options}}
                                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                                {{/each}}
                            </select>
                            {{/if}}
                            {{#if isTextarea}}
                            <textarea class="blacksmith-textarea blacksmith-json-import-prompt-field-textarea" data-prompt-field="{{id}}" rows="{{rows}}" autocomplete="off" placeholder="{{placeholder}}">{{value}}</textarea>
                            {{/if}}
                            {{#if isText}}
                            <input type="text" class="blacksmith-input blacksmith-json-import-prompt-field-input" data-prompt-field="{{id}}" value="{{value}}" autocomplete="off" placeholder="{{placeholder}}">
                            {{/if}}
                        </label>
                        {{/each}}
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                {{#if hasPromptCheckboxes}}
                <div class="blacksmith-json-import-prompt-options">
                    <span class="blacksmith-json-import-prompt-options-hint" data-for-template="area">Append to Area Narrative prompt:</span>
                    {{#each promptCheckboxGroups}}
                    <div class="blacksmith-json-import-prompt-group{{#if hasSection}} blacksmith-json-import-prompt-group-sectioned{{/if}}">
                        {{#if hasSection}}
                        <div class="blacksmith-json-import-prompt-section-header" data-for-template="{{showForTemplate}}" data-for-field="{{showForField}}">
                            <i class="{{sectionIcon}}"></i>
                            <span>{{section}}</span>
                        </div>
                        {{/if}}
                        <div class="blacksmith-json-import-prompt-group-items{{#if stacked}} blacksmith-json-import-prompt-group-items-stacked{{/if}}">
                            {{#each items}}
                            {{#if isNote}}
                            <div class="blacksmith-json-import-prompt-checkbox blacksmith-json-import-prompt-note" data-for-template="{{showForTemplate}}" data-for-field="{{showForField}}">
                                <span>{{label}}</span>
                            </div>
                            {{else}}
                            <label class="blacksmith-json-import-prompt-checkbox" data-for-template="{{showForTemplate}}" data-for-field="{{showForField}}">
                                <input type="checkbox" class="blacksmith-json-import-prompt-checkbox-input" data-prompt-checkbox="{{id}}" {{#if checked}}checked{{/if}} {{#if disabled}}disabled{{/if}}>
                                <span>{{label}}</span>
                            </label>
                            {{/if}}
                            {{/each}}
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </section>
    </div>

    <div class="blacksmith-json-import-tab-panel blacksmith-json-import-tab-panel-import" data-json-import-panel="import" {{#unless isImportTab}}hidden{{/unless}}>
        {{#if showImportResults}}
        <div class="blacksmith-json-import-results blacksmith-json-import-results-{{importResult.status}}">
            <div class="blacksmith-json-import-results-summary">
                <div>
                    <div class="blacksmith-json-import-results-title">{{importResult.operationLabel}} results</div>
                    <div class="blacksmith-json-import-results-counts">{{importResult.processed}} processed · {{importResult.succeeded}} succeeded · {{importResult.warned}} warnings · {{importResult.failed}} failed</div>
                </div>
                <span class="blacksmith-json-import-results-status">{{importResult.status}}</span>
            </div>
            <div class="blacksmith-json-import-results-list">
                {{#each importResult.entries}}
                <article class="blacksmith-json-import-result blacksmith-json-import-result-{{status}}">
                    <div class="blacksmith-json-import-result-heading">
                        <i class="{{statusIcon}}"></i>
                        <div class="blacksmith-json-import-result-identity">
                            <strong>{{inputName}}</strong>
                            <span>{{statusLabel}}{{#if profile}} · {{profile}}{{/if}}</span>
                        </div>
                        {{#if canOpen}}
                        <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-result-open" data-action="openDocument" data-uuid="{{document.uuid}}">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i> Open
                        </button>
                        {{/if}}
                        {{#if hasIssues}}
                        <button type="button" class="blacksmith-window-btn-secondary blacksmith-json-import-result-open" data-action="copyEntryIssues" data-entry-index="{{index}}">
                            <i class="fa-solid fa-copy"></i> Copy Issues
                        </button>
                        {{/if}}
                    </div>
                    {{#if warnings.length}}
                    <div class="blacksmith-json-import-result-issues">
                        {{#each warnings}}<div><i class="fa-solid fa-triangle-exclamation"></i> {{message}}</div>{{/each}}
                    </div>
                    {{/if}}
                    {{#if errors.length}}
                    <div class="blacksmith-json-import-result-issues">
                        {{#each errors}}<div><i class="fa-solid fa-circle-xmark"></i> {{message}}{{#if path}} <code>{{path}}</code>{{/if}}</div>{{/each}}
                    </div>
                    {{/if}}
                </article>
                {{/each}}
            </div>
        </div>
        {{else}}
        <textarea class="blacksmith-textarea blacksmith-json-import-textarea" placeholder="{{textareaPlaceholder}}">{{initialJson}}</textarea>
        {{/if}}
    </div>
</div>
