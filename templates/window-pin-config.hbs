<div class="blacksmith-pin-config" data-icon-mode="{{iconMode}}">
    <div class="window-note-header">
        <div class="window-note-header-content">
            <div class="window-note-header-title">
                <div class="blacksmith-pin-config-title"><i class="fa-solid fa-location-dot"></i> Configure Pin{{#if pinTypeLabel}} — {{pinTypeLabel}}{{/if}}</div>
            </div>
            <div class="window-note-header-controls">
                <div class="blacksmith-pin-config-toggle-container">
                    <span class="blacksmith-pin-config-toggle-label">Allow Duplicate Pins</span>
                    <div class="blacksmith-pin-config-toggle">
                        <input type="checkbox" id="blacksmith-pin-config-allow-duplicate" class="blacksmith-pin-config-allow-duplicate" {{#if pinAllowDuplicatePins}}checked{{/if}}>
                        <label for="blacksmith-pin-config-allow-duplicate" class="blacksmith-pin-config-toggle-slider"></label>
                    </div>
                </div>
                <div class="blacksmith-pin-config-toggle-container">
                    <span class="blacksmith-pin-config-toggle-label">Use as Default</span>
                    <div class="blacksmith-pin-config-toggle">
                        <input type="checkbox" id="blacksmith-pin-config-default-toggle" class="blacksmith-pin-config-default">
                        <label for="blacksmith-pin-config-default-toggle" class="blacksmith-pin-config-toggle-slider"></label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="window-note-body">
        {{#if isGM}}
        <div class="blacksmith-window-section blacksmith-pin-config-permissions-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-shield-halved"></i> Permissions</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field blacksmith-pin-config-permissions-default">
                        <span>Who can access this pin?</span>
                        <select class="blacksmith-input blacksmith-pin-config-ownership-default">
                            {{#each ownershipOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </label>
                </div>
                <div class="blacksmith-pin-config-help">
                    GM only (hidden): Only GMs see the pin. View: Players can see and click it (e.g. open journal). Edit: Players can also configure, move, or delete the pin.
                </div>
            </div>
        </div>
        {{/if}}
        {{#if isGM}}
        <div class="blacksmith-window-section blacksmith-pin-config-classification-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-layer-group"></i> Classification</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Group</span>
                        <input type="text" class="blacksmith-input blacksmith-pin-config-group" list="blacksmith-pin-config-group-list" value="{{pinGroup}}" placeholder="journal">
                        <datalist id="blacksmith-pin-config-group-list">
                            {{#each pinSuggestedGroups}}
                            <option value="{{this}}"></option>
                            {{/each}}
                        </datalist>
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Tags</span>
                        <input type="text" class="blacksmith-input blacksmith-pin-config-tags" value="{{pinTagsCsv}}" placeholder="journal-page, location">
                    </label>
                </div>
                <div class="blacksmith-pin-config-help">
                    {{pinClassificationHelp}} taxonomy. Use one group and comma-separated tags. Suggested tags:
                    {{#if pinSuggestedTags.length}}
                    {{#each pinSuggestedTags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}
                    {{else}}
                    None registered.
                    {{/if}}
                </div>
            </div>
        </div>
        {{/if}}
        <div class="blacksmith-window-section blacksmith-pin-config-design-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-ruler-combined"></i> Pin Design</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Width</span>
                        <input type="number" class="blacksmith-input blacksmith-pin-config-width" min="8" step="1" value="{{pinWidth}}">
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Height</span>
                        <input type="number" class="blacksmith-input blacksmith-pin-config-height" min="8" step="1" value="{{pinHeight}}">
                    </label>
                </div>
                <label class="blacksmith-pin-config-design-toggle">
                    <input type="checkbox" class="blacksmith-pin-config-lock" {{#if lockProportions}}checked{{/if}}>
                    Constrain proportions
                </label>
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Shape</span>
                        <select class="blacksmith-input blacksmith-pin-config-shape">
                            <option value="circle" {{#if (eq pinShape "circle")}}selected{{/if}}>Circle</option>
                            <option value="square" {{#if (eq pinShape "square")}}selected{{/if}}>Square</option>
                            <option value="none" {{#if (eq pinShape "none")}}selected{{/if}}>None</option>
                        </select>
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Background</span>
                        <div class="blacksmith-pin-config-color-row">
                            <input type="text" class="blacksmith-input blacksmith-pin-config-color-text blacksmith-pin-config-fill-text" value="{{pinFill}}">
                            <input type="color" class="blacksmith-pin-config-color-picker blacksmith-pin-config-fill" value="{{pinFill}}">
                        </div>
                    </label>
                </div>
                <div class="blacksmith-pin-config-help blacksmith-pin-config-shape-none-note" style="display: none;">
                    Shape “None” is icon-only and ignores background, border, and border width.
                </div>
                <div class="blacksmith-pin-config-design-row">
                    <div class="blacksmith-pin-config-design-field">
                        <span>Border</span>
                        <div class="blacksmith-pin-config-border-row">
                            <div class="blacksmith-pin-config-color-row">
                                <input type="text" class="blacksmith-input blacksmith-pin-config-color-text blacksmith-pin-config-stroke-text" value="{{pinStroke}}">
                                <input type="color" class="blacksmith-pin-config-color-picker blacksmith-pin-config-stroke" value="{{pinStroke}}">
                            </div>
                            <input type="number" class="blacksmith-input blacksmith-pin-config-stroke-width" min="0" step="1" value="{{pinStrokeWidth}}">
                        </div>
                    </div>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Icon Color</span>
                        <div class="blacksmith-pin-config-color-row">
                            <input type="text" class="blacksmith-input blacksmith-pin-config-color-text blacksmith-pin-config-icon-color-text" value="{{pinIconColor}}">
                            <input type="color" class="blacksmith-pin-config-color-picker blacksmith-pin-config-icon-color" value="{{pinIconColor}}">
                        </div>
                    </label>
                </div>
                <div class="blacksmith-pin-config-help blacksmith-pin-config-icon-mode-note" style="display: none;">
                    Icon color only applies to Font Awesome icons, not images.
                </div>
                <label class="blacksmith-pin-config-design-toggle">
                    <input type="checkbox" class="blacksmith-pin-config-shadow" {{#if pinDropShadow}}checked{{/if}}>
                    Drop shadow
                </label>
            </div>
        </div>

        <div class="blacksmith-window-section blacksmith-pin-config-text-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-font"></i> Text Format</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Text layout</span>
                        <select class="blacksmith-input blacksmith-pin-config-text-layout">
                            <option value="under" {{#if (eq pinTextLayout "under")}}selected{{/if}}>Below the Pin</option>
                            <option value="above" {{#if (eq pinTextLayout "above")}}selected{{/if}}>Above the Pin</option>
                            <option value="right" {{#if (eq pinTextLayout "right")}}selected{{/if}}>To the Right of the Pin</option>
                            <option value="left" {{#if (eq pinTextLayout "left")}}selected{{/if}}>To the Leftof the Pin</option>
                            <option value="arc-below" {{#if (eq pinTextLayout "arc-below")}}selected{{/if}}>Arc Below the Pin</option>
                            <option value="arc-above" {{#if (eq pinTextLayout "arc-above")}}selected{{/if}}>Arc Above the Pin</option>
                            <option value="over" {{#if (eq pinTextLayout "over")}}selected{{/if}}>Overlay the Pin</option>
                        </select>
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Text display</span>
                        <select class="blacksmith-input blacksmith-pin-config-text-display">
                            <option value="always" {{#if (eq pinTextDisplay "always")}}selected{{/if}}>Always</option>
                            <option value="hover" {{#if (eq pinTextDisplay "hover")}}selected{{/if}}>Hover</option>
                            <option value="never" {{#if (eq pinTextDisplay "never")}}selected{{/if}}>Never</option>
                            <option value="gm" {{#if (eq pinTextDisplay "gm")}}selected{{/if}}>GM only</option>
                        </select>
                    </label>
                </div>
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Text color</span>
                        <div class="blacksmith-pin-config-color-row">
                            <input type="text" class="blacksmith-input blacksmith-pin-config-color-text blacksmith-pin-config-text-color-text" value="{{pinTextColor}}">
                            <input type="color" class="blacksmith-pin-config-color-picker blacksmith-pin-config-text-color" value="{{pinTextColor}}">
                        </div>
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Text size</span>
                        <input type="number" class="blacksmith-input blacksmith-pin-config-text-size" min="6" step="1" value="{{pinTextSize}}">
                    </label>
                </div>
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Max characters</span>
                        <input type="number" class="blacksmith-input blacksmith-pin-config-text-max-length" min="0" step="1" value="{{pinTextMaxLengthDisplay}}" placeholder="">
                    </label>
                    <label class="blacksmith-pin-config-design-field">
                        <span>Chars per line</span>
                        <input type="number" class="blacksmith-input blacksmith-pin-config-text-max-width" min="0" step="1" value="{{pinTextMaxWidthDisplay}}" placeholder="" title="Max characters per line before wrap; empty = single line, no wrap">
                    </label>
                </div>
                <label class="blacksmith-pin-config-design-toggle">
                    <input type="checkbox" class="blacksmith-pin-config-text-scale" {{#if pinTextScaleWithPin}}checked{{/if}}>
                    Scale text with pin
                </label>
                <div class="blacksmith-pin-config-help blacksmith-pin-config-text-around-note" style="display: none;">
                    Arc text size and scaling are controlled by the pin-size ratio and ignore these settings.
                </div>
            </div>
        </div>

        <div class="blacksmith-window-section blacksmith-pin-config-animation-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-wand-sparkles"></i> Event Animations</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-help">Play an animation and optional sound when the pin is hovered, clicked, double-clicked, added to the canvas, or deleted. Right-click is reserved for the context menu.</div>
                <div class="blacksmith-pin-config-event-animations">
                    <div class="blacksmith-pin-config-event-row">
                        <span class="blacksmith-pin-config-event-label">Hover</span>
                        <select class="blacksmith-input blacksmith-pin-config-event-animation blacksmith-pin-config-event-hover-animation">
                            {{#each animationOptions}}
                            <option value="{{this.value}}" {{#if this.hoverSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                        <select class="blacksmith-input blacksmith-pin-config-event-sound blacksmith-pin-config-event-hover-sound">
                            {{#each soundOptions}}
                            <option value="{{this.value}}" {{#if this.hoverSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="blacksmith-pin-config-event-row">
                        <span class="blacksmith-pin-config-event-label">Click</span>
                        <select class="blacksmith-input blacksmith-pin-config-event-animation blacksmith-pin-config-event-click-animation">
                            {{#each animationOptions}}
                            <option value="{{this.value}}" {{#if this.clickSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                        <select class="blacksmith-input blacksmith-pin-config-event-sound blacksmith-pin-config-event-click-sound">
                            {{#each soundOptions}}
                            <option value="{{this.value}}" {{#if this.clickSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="blacksmith-pin-config-event-row">
                        <span class="blacksmith-pin-config-event-label">Double-click</span>
                        <select class="blacksmith-input blacksmith-pin-config-event-animation blacksmith-pin-config-event-doubleclick-animation">
                            {{#each animationOptions}}
                            <option value="{{this.value}}" {{#if this.doubleClickSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                        <select class="blacksmith-input blacksmith-pin-config-event-sound blacksmith-pin-config-event-doubleclick-sound">
                            {{#each soundOptions}}
                            <option value="{{this.value}}" {{#if this.doubleClickSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="blacksmith-pin-config-event-row">
                        <span class="blacksmith-pin-config-event-label">Add (to canvas)</span>
                        <select class="blacksmith-input blacksmith-pin-config-event-animation blacksmith-pin-config-event-add-animation">
                            {{#each animationOptions}}
                            <option value="{{this.value}}" {{#if this.addSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                        <select class="blacksmith-input blacksmith-pin-config-event-sound blacksmith-pin-config-event-add-sound">
                            {{#each soundOptions}}
                            <option value="{{this.value}}" {{#if this.addSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="blacksmith-pin-config-event-row">
                        <span class="blacksmith-pin-config-event-label">Delete</span>
                        <select class="blacksmith-input blacksmith-pin-config-event-animation blacksmith-pin-config-event-delete-animation">
                            {{#each deleteAnimationOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                        <select class="blacksmith-input blacksmith-pin-config-event-sound blacksmith-pin-config-event-delete-sound">
                            {{#each soundOptions}}
                            <option value="{{this.value}}" {{#if this.deleteSelected}}selected{{/if}}>{{this.label}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="blacksmith-pin-config-source-toggle">
            <span class="blacksmith-pin-config-source-label">Image</span>
            <div class="blacksmith-pin-config-source-switch">
                <input type="checkbox" id="blacksmith-pin-config-source-toggle" class="blacksmith-pin-config-source-toggle-input" {{#if (eq iconMode 'icon')}}checked{{/if}}>
                <label for="blacksmith-pin-config-source-toggle" class="blacksmith-pin-config-source-toggle-slider"></label>
            </div>
            <span class="blacksmith-pin-config-source-label">Icon</span>
        </div>

        <div class="blacksmith-window-section blacksmith-pin-config-image-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-image"></i> Image URL</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-design-row">
                    <label class="blacksmith-pin-config-design-field">
                        <span>Image Fit</span>
                        <select class="blacksmith-input blacksmith-pin-config-image-fit">
                            <option value="cover" {{#if (eq pinImageFit "cover")}}selected{{/if}}>Cover</option>
                            <option value="contain" {{#if (eq pinImageFit "contain")}}selected{{/if}}>Contain</option>
                            <option value="fill" {{#if (eq pinImageFit "fill")}}selected{{/if}}>Fill</option>
                            <option value="none" {{#if (eq pinImageFit "none")}}selected{{/if}}>Actual Size</option>
                            <option value="scale-down" {{#if (eq pinImageFit "scale-down")}}selected{{/if}}>Scale Down</option>
                            <option value="zoom" {{#if (eq pinImageFit "zoom")}}selected{{/if}}>Zoom</option>
                        </select>
                    </label>
                    <div class="blacksmith-pin-config-image-zoom-row {{#unless showImageZoomSlider}}is-hidden{{/unless}}" data-zoom-row>
                        <label class="blacksmith-pin-config-design-field">
                            <span>Zoom level</span>
                            <div class="blacksmith-pin-config-zoom-control">
                                <input type="range" class="blacksmith-pin-config-image-zoom" min="100" max="200" step="5" value="{{pinImageZoomPercent}}" title="100% = same as Cover">
                                <span class="blacksmith-pin-config-zoom-value">{{pinImageZoomPercent}}%</span>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="blacksmith-pin-config-image-row">
                    <input type="text" class="blacksmith-input blacksmith-pin-config-image-input" placeholder="Paste image URL..." value="{{imageValue}}">
                    <button type="button" class="btn-secondary blacksmith-pin-config-browse"><i class="fa-solid fa-folder-open"></i> Browse</button>
                </div>
                <div class="blacksmith-pin-config-image-preview-wrap">
                    <img class="blacksmith-pin-config-image-preview {{#unless imageValue}}is-hidden{{/unless}}" src="{{imageValue}}" alt="Pin preview">
                </div>
            </div>
        </div>

        <div class="blacksmith-window-section blacksmith-pin-config-library-section">
            <div class="blacksmith-window-section-header"><i class="fa-solid fa-icons"></i> Icon Library</div>
            <div class="blacksmith-window-section-body">
                <div class="blacksmith-pin-config-icon-filters">
                    <input type="text" class="blacksmith-input blacksmith-pin-config-icon-search" placeholder="Search icons...">
                    <select class="blacksmith-input blacksmith-pin-config-icon-category-filter">
                        <option value="all">All categories</option>
                        {{#each iconCategoryOptions}}
                            <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                </div>
                {{#each iconCategories}}
                <div class="blacksmith-pin-config-icon-category">
                    <div class="blacksmith-pin-config-icon-category-title">{{this.category}}</div>
                    {{#if this.description}}
                        <div class="blacksmith-pin-config-icon-category-description">{{this.description}}</div>
                    {{/if}}
                    <div class="blacksmith-pin-config-icon-grid">
                        {{#each this.icons}}
                        <button type="button" class="blacksmith-pin-config-icon-option {{#if this.isSelected}}selected{{/if}}" data-type="fa" data-value="{{this.value}}" data-label="{{this.label}}" data-category="{{../category}}" title="{{this.label}}">
                            <i class="{{this.value}}"></i>
                        </button>
                        {{/each}}
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="button" class="btn-secondary cancel">
            <i class="fa-solid fa-times"></i> Cancel
        </button>
        <button type="button" class="btn-primary blacksmith-pin-config-save">
            <i class="fa-solid fa-check"></i> Save pin design
        </button>
    </div>
</div>
