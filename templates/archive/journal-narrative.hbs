{{#if (or 
    (and strRealm (ne strRealm ""))
    (and strRegion (ne strRegion ""))
    (and strArea (ne strArea ""))
    (and strSite (ne strSite ""))
    (and strSceneTitle (ne strSceneTitle "")))}}
<h5>
    {{~#if (and strRealm (ne strRealm ""))}}{{strRealm}}{{/if~}}
    {{~#if (and strRegion (ne strRegion ""))}}{{#if (and strRealm (ne strRealm ""))}} • {{/if}}{{strRegion}}{{/if~}}
    {{~#if (and strArea (ne strArea ""))}}{{#if (or (and strRealm (ne strRealm "")) (and strRegion (ne strRegion "")))}} • {{/if}}{{strArea}}{{/if~}}
    {{~#if (and strSite (ne strSite ""))}} ({{strSite}}){{/if~}}
    {{~#if (and strSceneTitle (ne strSceneTitle ""))}}{{#if (or (and strRealm (ne strRealm "")) (and strRegion (ne strRegion "")) (and strArea (ne strArea "")))}} • {{/if}}{{strSceneTitle}}{{/if~}}
</h5>
{{/if}}

<h2>Preparation</h2>
{{#if (and strPrepEncounter (ne strPrepEncounter ""))}}
    <h4>Encounter Logistics</h4>
    <h5>Monsters and NPCs</h5>
    {{{strPrepEncounter}}}
    {{#if (and strPrepEncounterDetails (ne strPrepEncounterDetails ""))}}
    <h5>Encounter Details</h5>
    {{{strPrepEncounterDetails}}}
    {{/if}}
{{/if}}

{{#if (and strPrepRewards (ne strPrepRewards "") (ne strPrepRewards "<ul>None</ul>"))}}
    <h4>Rewards and Treasure</h4>
    {{{strPrepRewards}}}
{{/if}}

{{#if (and strPrepSetup (ne strPrepSetup ""))}}
    <h4>Summary and Setup</h4>
    {{{strPrepSetup}}}
{{/if}}

{{#if (and strSceneTitle (ne strSceneTitle ""))}}
<h2>{{strSceneTitle}}</h2>
{{/if}}

{{#if (and strContextIntro (ne strContextIntro ""))}}
{{{strContextIntro}}}
{{/if}}

{{#each sections}}
<p></p>
<section class="narrative-section">
  {{#if (and this.strSectionTitle (ne this.strSectionTitle ""))}}
  <h2>{{this.strSectionTitle}}</h2>
  {{/if}}
  {{#if (and this.strSectionIntro (ne this.strSectionIntro ""))}}
  <div class="narrative-section-intro">{{{this.strSectionIntro}}}</div>
  {{/if}}
  {{#each this.cards}}
  {{#if (or 
    (and this.strCardDescriptionPrimary (ne this.strCardDescriptionPrimary ""))
    (and this.strCardImage (ne this.strCardImage "") (ne this.strCardImage "null")))}}
    <blockquote>
        {{#if (and this.strCardTitle (ne this.strCardTitle ""))}}
        <h4>{{this.strCardTitle}}</h4>
        {{/if}}
        {{#if (and this.strCardDescriptionPrimary (ne this.strCardDescriptionPrimary ""))}}
        <p>{{this.strCardDescriptionPrimary}}</p>
        {{/if}}
        {{#if (and this.strCardImage (ne this.strCardImage "") (ne this.strCardImage "null"))}}
            {{#if (and this.strCardImageTitle (ne this.strCardImageTitle ""))}}
            <h5>{{this.strCardImageTitle}}</h5>
            {{/if}}
            <img src="{{{this.strCardImage}}}">
            <hr>
        {{/if}}
        {{#if (and this.strCardDescriptionSecondary (ne this.strCardDescriptionSecondary ""))}}
        <p>{{this.strCardDescriptionSecondary}}</p>
        {{/if}}
        {{#if (and this.strCardDialogue (ne this.strCardDialogue "") (ne this.strCardDialogue " "))}}
            {{{this.strCardDialogue}}}
        {{/if}}
    </blockquote>
  {{/if}}
  {{/each}}
  {{#if (and this.strContextAdditionalNarration (ne this.strContextAdditionalNarration ""))}}
    <h4>Extended Narrative</h4>
    {{{this.strContextAdditionalNarration}}}
  {{/if}}
  {{#if (and this.strContextGMNotes (ne this.strContextGMNotes ""))}}
    <h4>Notes and Strategies</h4>
    {{{this.strContextGMNotes}}}
  {{/if}}
  {{#if (and this.strContextAtmosphere (ne this.strContextAtmosphere ""))}}
    <h4>Atmosphere and Environments</h4>
    {{{this.strContextAtmosphere}}}
  {{/if}}
</section>
{{/each}}

{{!-- Include the hidden linked encounters data --}}
{{{linkedEncountersData}}}

{{!-- Display linked encounters in a more readable format --}}
{{#if linkedEncounters}}
<h4>Related Encounters</h4>
<div class="related-encounters">
    {{#each linkedEncounters}}
    <div class="encounter-reference">
        <h5>@UUID[{{this.uuid}}]{{this.name}}</h5>
        {{#if this.synopsis}}
        <p><strong>Synopsis:</strong> {{this.synopsis}}</p>
        {{/if}}
        {{#if this.keyMoments}}
        <p><strong>Key Moments:</strong> {{#each this.keyMoments}}{{#unless @first}}, {{/unless}}{{this}}{{/each}}</p>
        {{/if}}
    </div>
    {{/each}}
</div>
{{/if}}

{{!-- Include the hidden linked encounters data --}}
